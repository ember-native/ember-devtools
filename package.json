{
  "name": "ember-native-devtools",
  "version": "3.0.2",
  "description": "Ember Inspector for Node.js environments using WebSocket",
  "repository": {
    "type": "git",
    "url": "git@github.com:ember-native/ember-devtools.git"
  },
  "type": "module",
  "main": "src/inspector-server.mjs",
  "exports": {
    ".": "./src/inspector-server.js",
    "./server": "./src/inspector-server.js",
    "./client": "./src/setup-inspector.js"
  },
  "bin": {
    "ember-inspector-server": "src/inspector-server.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "start": "node src/inspector-server.mjs",
    "server": "node src/inspector-server.mjs"
  },
  "keywords": [
    "ember",
    "inspector",
    "devtools",
    "debugging",
    "websocket",
    "nodejs",
    "ssr",
    "fastboot"
  ],
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.8.1",
    "ember-inspector": "^4.15.1"
  },
  "peerDependencies": {
    "socket.io-client": "^4.0.0"
  },
  "devDependencies": {
    "release-plan": "^0.18.0"
  },
  "author": "Patrick Pircher",
  "license": "MIT"
}
